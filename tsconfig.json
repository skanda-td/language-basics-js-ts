{
  "compilerOptions": {
    /* ===== Runtime Target ===== */
    "target": "ES2020",
    "module": "NodeNext",

    /* ===== Project Structure ===== */
    "rootDir": "src/ts",
    "outDir": "dist",

    /* ===== Type Safety ===== */
    "strict": true,
    "noEmitOnError": true,

    /* ===== Node Compatibility ===== */
    "esModuleInterop": true,
    "types": ["node"],
    "skipLibCheck": true,

    /* ===== Output ===== */
    "sourceMap": true,

    /* ===== Disabled (avoid extra files) ===== */
    "declaration": false,
    "declarationMap": false
  },

  "include": ["src/ts/**/*"],
  "exclude": ["node_modules", "dist"]
}